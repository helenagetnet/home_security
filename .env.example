# Copy this file to .env if you want to override any default.
# Every value already has a working default in the code, so .env is optional.

MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1886
MQTT_TOPIC_NETWORK=home/network
MQTT_TOPIC_EVENTS=home/events
MQTT_TOPIC_TELEMETRY=home/telemetry
MQTT_TOPIC_DEVICE_STATUS=home/device_status

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3311
MYSQL_USER=homeuser
MYSQL_PASSWORD=homepass
MYSQL_DATABASE=home_security

MONGODB_URI=mongodb://root:rootpass@localhost:27021/
MONGODB_DB=home_security
MONGODB_TELEMETRY_COLLECTION=device_messages
MONGODB_STATUS_COLLECTION=device_status
MONGODB_LOGS_COLLECTION=device_logs

NEO4J_URI=bolt://localhost:7690
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
